# Optional: improves set search (https://rebrickable.com/api/)
# REBRICKABLE_API_KEY=

# BrickLink API (https://www.bricklink.com/v2/api/register_consumer.page)
# BRICKLINK_CONSUMER_KEY=
# BRICKLINK_CONSUMER_SECRET=
# BRICKLINK_TOKEN=
# BRICKLINK_TOKEN_SECRET=

# Server port (default 3456)
PORT=3456

# Optional: path to CSV for `npm run import` or first-run auto-import
# IMPORT_CSV_PATH=/app/import/lego_collection_valuation.csv

# Daily automatic price refresh (runs while server/container is up)
# Set to false to disable the in-process scheduler
DAILY_REFRESH_ENABLED=true
# Local time — default 03:00
DAILY_REFRESH_HOUR=3
DAILY_REFRESH_MINUTE=0
